PORT=4100

# URL del contenedor Gotenberg (conversión docx -> PDF vía LibreOffice headless).
# Dentro de docker-compose usar el nombre del servicio: http://gotenberg:3000
# Fuera de Docker (dev local con Gotenberg corriendo suelto): http://localhost:3000
GOTENBERG_URL=http://gotenberg:3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=marietta_contratos

# Cambiar por un valor propio y secreto en cada entorno.
JWT_SECRET=cambia-este-valor-en-produccion
JWT_EXPIRES_IN=8h

# Credenciales del usuario admin que crea `npm run seed` (solo si aún no existe ese usuario).
SEED_ADMIN_USUARIO=admin
SEED_ADMIN_PASSWORD=cambiar123
